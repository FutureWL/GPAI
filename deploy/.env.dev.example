# GPAI local dev environment — copy to `.env` (which is gitignored)
# Used by scripts/dev-up.sh, scripts/db-migrate.sh, scripts/db-seed.sh,
# and the four background processes (market-server, ingestor, gateway, web).

# Database (host-side port matches deploy/docker-compose.dev.yml)
DATABASE_URL=postgres://gpai:gpai@localhost:55432/gpai

# Cache
REDIS_URL=redis://localhost:6390

# Gateway (Go)
GATEWAY_URL=http://localhost:8080
GATEWAY_PORT=8080

# Market-server (Rust gRPC) — bound addr (no scheme)
MARKET_ADDR=127.0.0.1:50051
# Consumed by core-ingestor and apps/gateway (http:// scheme)
MARKET_GRPC_ADDR=http://127.0.0.1:50051

# Ingestor (Rust)
INGESTOR_POLL_SECS=30
INGESTOR_INSTRUMENTS=US.AAPL.NASDAQ

# Logging
RUST_LOG=info,gpai=debug
